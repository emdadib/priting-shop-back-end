generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  username           String              @unique
  password           String
  firstName          String
  lastName           String
  role               UserRole            @default(STAFF)
  isActive           Boolean             @default(true)
  lastLogin          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  attendance         Attendance[]
  auditLogs          AuditLog[]
  commissions        Commission[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]
  orders             Order[]
  payments           Payment[]
  purchaseOrders     PurchaseOrder[]
  warrantiesCreated  Warranty[] @relation("WarrantyCreatedBy")
  warrantiesAssigned Warranty[] @relation("WarrantyAssignedTo")
  permissions        UserPermission[]
  menuPermissions    UserMenuPermission[]
  grantedPermissions UserPermission[] @relation("PermissionGrantedBy")
  grantedMenuPermissions UserMenuPermission[] @relation("MenuPermissionGrantedBy")
  salaries         Salary[]
  salariesPaid     Salary[] @relation("SalaryPaidBy")
  salaryAdvances   SalaryAdvance[]
  advancesApproved SalaryAdvance[] @relation("AdvanceApprovedBy")
  advancesPaid     SalaryAdvance[] @relation("AdvancePaidBy")
  salaryProfile    EmployeeSalaryProfile?
  salaryPayments              SalaryPayment[]
  salaryPaymentsPaid          SalaryPayment[]              @relation("SalaryPaymentPaidBy")
  attendanceSalaryDeductions AttendanceSalaryDeduction[]
  employeeLeaves             EmployeeLeave[]
  reviewedLeaves             EmployeeLeave[]           @relation("LeaveReviewedBy")

  @@map("users")
}

model Customer {
  id            String                @id @default(cuid())
  firstName     String
  lastName      String
  email         String?               @unique
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  country       String?               @default("BD")
  company       String?
  taxId         String?
  isActive      Boolean               @default(true)
  isWalkIn      Boolean               @default(false)
  loyaltyPoints Int                   @default(0)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  transactions  CustomerTransaction[]
  invoices      Invoice[]
  orders        Order[]
  payments      Payment[]
  warranties    Warranty[]

  @@map("customers")
}

model Supplier {
  id             String                @id @default(cuid())
  name           String
  company        String
  email          String?               @unique
  phone          String
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?               @default("BD")
  taxId          String?
  contactPerson  String?
  contactPhone   String?
  website        String?
  paymentTerms   String?
  creditLimit    Decimal?              @db.Decimal(10, 2)
  isActive       Boolean               @default(true)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  payments       Payment[]
  products       Product[]
  purchaseOrders PurchaseOrder[]
  transactions   SupplierTransaction[]

  @@map("suppliers")
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  poNumber         String              @unique
  supplierId       String
  userId           String
  status           PurchaseOrderStatus @default(DRAFT)
  orderDate        DateTime            @default(now())
  expectedDelivery DateTime?
  subtotal         Decimal             @db.Decimal(10, 2)
  taxAmount        Decimal             @db.Decimal(10, 2)
  discountAmount   Decimal             @default(0) @db.Decimal(10, 2)
  total            Decimal             @db.Decimal(10, 2)
  paidAmount       Decimal             @default(0) @db.Decimal(10, 2)
  dueAmount        Decimal             @default(0) @db.Decimal(10, 2)
  paymentStatus    PaymentStatus       @default(PENDING)
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  items            PurchaseOrderItem[]
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  user             User                @relation(fields: [userId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantity         Int
  unitPrice        Decimal       @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  receivedQuantity Int           @default(0)
  notes            String?
  createdAt        DateTime      @default(now())
  product          Product       @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  parentId    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@map("categories")
}

model Product {
  id                     String               @id @default(cuid())
  name                   String
  description            String?
  sku                    String               @unique
  barcode                String?              @unique
  categoryId             String
  type                   ProductType
  pricingModel           PricingModel         @default(FIXED)
  basePrice              Decimal              @db.Decimal(10, 2)
  baseCostPrice          Decimal              @db.Decimal(10, 2)
  taxRate                Decimal              @default(0) @db.Decimal(5, 4)
  isActive               Boolean              @default(true)
  isService              Boolean              @default(false)
  hasInventory           Boolean              @default(false)
  minStock               Int                  @default(0)
  maxStock               Int?
  unit                   String               @default("piece")
  weight                 Decimal?             @db.Decimal(8, 3)
  dimensions             String?
  imageUrl               String?
  specifications         Json?
  isCustomOrder          Boolean              @default(true)
  requiresSpecifications Boolean              @default(false)
  hasWarranty            Boolean              @default(false)
  warrantyPeriod         Int?                 // Warranty period in days
  warrantyPeriodType     WarrantyPeriodType?  // Type of warranty period (6 months, 1 year, etc.)
  warrantyDescription    String?              // Warranty terms and conditions
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  supplierId             String?
  inventory              Inventory?
  inventoryMovements     InventoryMovement[]  @relation("ProductMovements")
  orderItems             OrderItem[]
  priceHistory           PriceHistory[]
  productPricingTiers    ProductPricingTier[]
  category               Category             @relation(fields: [categoryId], references: [id])
  supplier               Supplier?            @relation(fields: [supplierId], references: [id])
  purchaseOrderItems     PurchaseOrderItem[]
  warranties             Warranty[]
  warrantyReplacements   Warranty[] @relation("WarrantyReplacement")

  @@map("products")
}

model ProductPricingTier {
  id          String   @id @default(cuid())
  productId   String
  minQuantity Int
  maxQuantity Int?
  unitPrice   Decimal  @db.Decimal(10, 2)
  costPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([productId, minQuantity])
  @@map("product_pricing_tiers")
}

model Warranty {
  id                String        @id @default(cuid())
  productId         String
  orderId           String
  customerId        String
  warrantyNumber    String        @unique
  issueDescription  String
  status            WarrantyStatus @default(OPEN)
  priority          WarrantyPriority @default(MEDIUM)
  reportedDate      DateTime      @default(now())
  resolvedDate      DateTime?
  resolution        String?
  replacementProductId String?
  refundAmount      Decimal?      @db.Decimal(10, 2)
  notes             String?
  createdBy         String
  assignedTo        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  product           Product       @relation(fields: [productId], references: [id])
  order             Order         @relation(fields: [orderId], references: [id])
  customer          Customer      @relation(fields: [customerId], references: [id])
  createdByUser     User          @relation("WarrantyCreatedBy", fields: [createdBy], references: [id])
  assignedToUser    User?         @relation("WarrantyAssignedTo", fields: [assignedTo], references: [id])
  replacementProduct Product?     @relation("WarrantyReplacement", fields: [replacementProductId], references: [id])

  @@map("warranties")
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerId     String?
  userId         String
  status         OrderStatus   @default(PENDING)
  type           OrderType     @default(SALE)
  orderType      OrderTypeEnum @default(CUSTOM)
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  notes          String?
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoices       Invoice[]
  items          OrderItem[]
  customer       Customer?     @relation(fields: [customerId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  payments       Payment[]
  warranties     Warranty[]

  @@map("orders")
}

model OrderItem {
  id                 String  @id @default(cuid())
  orderId            String
  productId          String
  quantity           Int
  unit               String  @default("piece")
  unitPrice          Decimal @db.Decimal(10, 2)
  costPrice          Decimal @db.Decimal(10, 2)
  discount           Decimal @default(0) @db.Decimal(10, 2)
  taxAmount          Decimal @db.Decimal(10, 2)
  total              Decimal @db.Decimal(10, 2)
  notes              String?
  specifications     Json?
  customDimensions   String?
  customRequirements String?
  isCustomPriced     Boolean @default(false)
  serialNumbers      String? // Comma-separated serial numbers for individual product tracking
  warrantyStartDate  DateTime? // When warranty starts (usually order completion date)
  warrantyEndDate    DateTime? // When warranty expires
  order              Order   @relation(fields: [orderId], references: [id])
  product            Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Inventory {
  id                 String              @id @default(cuid())
  productId          String              @unique
  quantity           Int                 @default(0)
  reserved           Int                 @default(0)
  available          Int                 @default(0)
  lastUpdated        DateTime            @default(now())
  product            Product             @relation(fields: [productId], references: [id])

  @@map("inventory")
}

model InventoryMovement {
  id               String       @id @default(cuid())
  productId        String
  type             MovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  reference        String?
  userId           String
  createdAt        DateTime     @default(now())
  product          Product      @relation("ProductMovements", fields: [productId], references: [id], map: "InventoryMovement_productId_fkey")
  user             User         @relation(fields: [userId], references: [id])

  @@map("inventory_movements")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  orderId        String?
  customerId     String?
  userId         String
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer?     @relation(fields: [customerId], references: [id])
  order          Order?        @relation(fields: [orderId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  payments       Payment[]

  @@map("invoices")
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String?
  invoiceId   String?
  customerId  String?
  userId      String
  amount      Decimal       @db.Decimal(10, 2)
  method      PaymentMethod
  reference   String?
  status      PaymentStatus @default(PENDING)
  processedAt DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  supplierId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id])
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  order       Order?        @relation(fields: [orderId], references: [id])
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Attendance {
  id          String           @id @default(cuid())
  userId      String
  date        DateTime         @db.Date
  checkIn     DateTime?        @map("clockIn")
  checkOut    DateTime?        @map("clockOut")
  lunchOut    DateTime?        @map("breakStart")
  lunchIn     DateTime?        @map("breakEnd")
  totalHours  Decimal?         @db.Decimal(4, 2)
  status      AttendanceStatus @default(PRESENT)
  isLate      Boolean          @default(false)
  lateMinutes Int              @default(0)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

model Commission {
  id        String           @id @default(cuid())
  userId    String
  orderId   String?
  amount    Decimal          @db.Decimal(10, 2)
  rate      Decimal          @db.Decimal(5, 4)
  period    String
  status    CommissionStatus @default(PENDING)
  paidAt    DateTime?
  notes     String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@map("commissions")
}

model Salary {
  id          String      @id @default(cuid())
  userId      String
  amount      Decimal     @db.Decimal(10, 2)
  month       Int         // 1-12
  year        Int         // e.g., 2024
  status      SalaryStatus @default(PENDING)
  paidAt      DateTime?
  paidBy      String?     // User ID who processed the payment
  notes       String?
  deductions  Decimal?    @db.Decimal(10, 2) // Any deductions
  bonuses     Decimal?    @db.Decimal(10, 2) // Any bonuses
  advances    Decimal?    @db.Decimal(10, 2) // Total advances taken this month
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  user        User        @relation(fields: [userId], references: [id])
  paidByUser  User?       @relation("SalaryPaidBy", fields: [paidBy], references: [id])
  salaryAdvances SalaryAdvance[]

  @@unique([userId, month, year])
  @@map("salaries")
}

model SalaryAdvance {
  id          String      @id @default(cuid())
  userId      String
  salaryId    String?     // Link to salary record if exists
  amount      Decimal     @db.Decimal(10, 2)
  requestDate DateTime    @default(now())
  approvedBy  String?     // User ID who approved the advance
  approvedAt  DateTime?
  paidBy      String?     // User ID who processed the payment
  paidAt      DateTime?
  status      AdvanceStatus @default(PENDING)
  reason      String?     // Reason for advance
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  user        User        @relation(fields: [userId], references: [id])
  salary      Salary?     @relation(fields: [salaryId], references: [id])
  approvedByUser User?    @relation("AdvanceApprovedBy", fields: [approvedBy], references: [id])
  paidByUser  User?       @relation("AdvancePaidBy", fields: [paidBy], references: [id])

  @@map("salary_advances")
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  WEEKEND
  HOLIDAY
  ON_LEAVE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ShopClosure {
  id        String   @id @default(cuid())
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
  @@map("shop_closures")
}

model EmployeeLeave {
  id          String             @id @default(cuid())
  userId      String
  startDate   DateTime           @db.Date
  endDate     DateTime           @db.Date
  leaveType   String             @default("ANNUAL")
  reason      String?
  status      LeaveRequestStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer    User?              @relation("LeaveReviewedBy", fields: [reviewedBy], references: [id])

  @@index([userId, status])
  @@index([startDate, endDate])
  @@map("employee_leaves")
}

enum SalaryStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum AdvanceStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

model EmployeeSalaryProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  baseSalary  Decimal  @db.Decimal(10, 2) // Monthly base salary amount
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime? // When salary was changed/ended
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id])
  salaryPayments SalaryPayment[]
  
  @@map("employee_salary_profiles")
}

model SalaryPayment {
  id          String      @id @default(cuid())
  userId      String
  profileId   String      // Link to salary profile
  amount      Decimal     @db.Decimal(10, 2) // Actual amount paid (can differ from base)
  month       Int         // 1-12
  year        Int         // e.g., 2024
  status      SalaryPaymentStatus @default(PENDING)
  paidAt      DateTime?
  paidBy      String?     // User ID who processed the payment
  deductions  Decimal?    @db.Decimal(10, 2) // Any deductions
  bonuses     Decimal?    @db.Decimal(10, 2) // Any bonuses
  advances    Decimal?    @db.Decimal(10, 2) // Total advances taken this month
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  user        User        @relation(fields: [userId], references: [id])
  profile     EmployeeSalaryProfile @relation(fields: [profileId], references: [id])
  paidByUser  User?       @relation("SalaryPaymentPaidBy", fields: [paidBy], references: [id])
  
  @@unique([userId, month, year])
  @@map("salary_payments")
}

enum SalaryPaymentStatus {
  PENDING
  PAID
  CANCELLED
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  oldPrice  Decimal  @db.Decimal(10, 2)
  newPrice  Decimal  @db.Decimal(10, 2)
  reason    String?
  userId    String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@map("price_history")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AttendanceConfig {
  id                      String   @id @default(cuid())
  checkInTime             String   @default("10:00")
  checkInLateThreshold    String   @default("10:30")
  lunchBreakStartEarliest String   @default("13:00")
  lunchBreakEndLatest     String   @default("15:00")
  checkOutTime            String   @default("20:30")
  weekendDays             String   @default("[5]")
  lateCountThreshold      Int      @default(3)
  absentDaysThreshold     Int      @default(2)
  lunchBreakMandatory     Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("attendance_config")
}

model AttendanceSalaryDeduction {
  id                  String   @id @default(cuid())
  userId              String
  month               Int
  year                Int
  lateDays            Int      @default(0)
  absentDays          Int      @default(0)
  lateDeductionDays   Decimal  @default(0) @db.Decimal(4, 2)
  absentDeductionDays Decimal  @default(0) @db.Decimal(4, 2)
  totalDeductionDays  Decimal  @default(0) @db.Decimal(4, 2)
  deductionAmount     Decimal  @default(0) @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@map("attendance_salary_deductions")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model CustomerTransaction {
  id            String          @id @default(cuid())
  customerId    String
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  description   String
  reference     String?
  referenceType ReferenceType?
  referenceId   String?
  date          DateTime        @default(now())
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  customer      Customer        @relation(fields: [customerId], references: [id])

  @@map("customer_transactions")
}

model SupplierTransaction {
  id            String          @id @default(cuid())
  supplierId    String
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  description   String
  reference     String?
  referenceType ReferenceType?
  referenceId   String?
  date          DateTime        @default(now())
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  supplier      Supplier        @relation(fields: [supplierId], references: [id])

  @@map("supplier_transactions")
}

model CompanyTransaction {
  id            String          @id @default(cuid())
  accountType   AccountType
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  description   String?
  reference     String?
  referenceType ReferenceType?
  referenceId   String?
  expenseCategoryId String?
  date          DateTime        @default(now())
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])

  @@map("company_transactions")
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  transactions CompanyTransaction[]

  @@map("expense_categories")
}

model Loan {
  id              String      @id @default(cuid())
  loanNumber      String      @unique
  lenderName      String
  lenderType      LenderType  @default(BANK)
  loanType        LoanType    @default(BUSINESS)
  principalAmount Decimal     @db.Decimal(12, 2)
  interestRate    Decimal     @db.Decimal(5, 2)
  loanTerm        Int         // in months
  startDate       DateTime
  endDate         DateTime
  status          LoanStatus  @default(ACTIVE)
  purpose         String?
  notes           String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  payments        LoanPayment[]

  @@map("loans")
}

model LoanPayment {
  id              String      @id @default(cuid())
  loanId          String
  paymentNumber   Int
  paymentDate     DateTime
  principalAmount Decimal     @db.Decimal(12, 2)
  interestAmount  Decimal     @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  remainingBalance Decimal    @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH)
  status          PaymentStatus @default(COMPLETED)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  loan            Loan        @relation(fields: [loanId], references: [id])

  @@map("loan_payments")
}

enum LenderType {
  BANK
  FINANCIAL_INSTITUTION
  PRIVATE_LENDER
  GOVERNMENT
  FRIEND_FAMILY
  OTHER
}

enum LoanType {
  BUSINESS
  EQUIPMENT
  WORKING_CAPITAL
  EXPANSION
  EMERGENCY
  OTHER
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
