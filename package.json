{
  "name": "printing-shop-server",
  "version": "1.0.0",
  "description": "Backend API for Printing Shop Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "node ../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma && node ../node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "start": "node dist/index.js",
    "postinstall": "node ../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "setup-db": "node ../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma && node ../node_modules/prisma/build/index.js db push --schema prisma/schema.prisma",
    "migrate": "node ../node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
    "migrate:deploy": "node ../node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "studio": "node ../node_modules/prisma/build/index.js studio --schema prisma/schema.prisma",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "3.0.3",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.10",
    "prisma": "5.22.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.14.202",
    "@types/moment": "^2.13.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "printing-shop",
    "api",
    "express",
    "typescript",
    "prisma"
  ],
  "author": "Printing Shop Management Team",
  "license": "MIT"
}
